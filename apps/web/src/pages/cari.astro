---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/Icon.astro";
import { policies, categories } from "../data/mockData";

const query = Astro.url.searchParams.get("q") || "";
const filteredPolicies = query
  ? policies.filter(
      (p) =>
        p.title.toLowerCase().includes(query.toLowerCase()) ||
        p.number.toLowerCase().includes(query.toLowerCase()) ||
        p.summary.toLowerCase().includes(query.toLowerCase()),
    )
  : [];

const catMap = Object.fromEntries(categories.map((c) => [c.slug, c]));

const typeBadge: Record<string, string> = {
  Perda:
    "inline-flex items-center text-[0.65rem] font-mono font-semibold px-1.5 py-0.5 rounded bg-bird-50 text-bird-700 border border-bird-200",
  Perbup:
    "inline-flex items-center text-[0.65rem] font-mono font-semibold px-1.5 py-0.5 rounded bg-teluk-50 text-teluk-700 border border-teluk-200",
  "SK Bupati":
    "inline-flex items-center text-[0.65rem] font-mono font-semibold px-1.5 py-0.5 rounded bg-paper-100 text-ink-600 border border-paper-300",
  Pergub:
    "inline-flex items-center text-[0.65rem] font-mono font-semibold px-1.5 py-0.5 rounded bg-gold-50 text-gold-700 border border-gold-200",
};
---

<MainLayout title={query ? `"${query}" — Cari — Kastau` : "Cari — Kastau"}>
  <div class="max-w-4xl mx-auto px-6 py-10">
    <div class="mb-8">
      <h1 class="font-semibold text-ink-900 text-3xl mb-5">Cari Kebijakan</h1>
      <form action="/cari" method="get" class="relative">
        <Icon
          name="search"
          class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-ink-300 pointer-events-none"
        />
        <input
          type="text"
          name="q"
          value={query}
          autofocus
          placeholder="Cari judul, nomor, atau topik kebijakan..."
          class="w-full bg-white border border-paper-300 text-ink-800 placeholder-ink-300 rounded-xl pl-12 pr-32 py-3.5 text-[15px] focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all shadow-sm"
        />
        <button
          type="submit"
          class="absolute right-2 top-1/2 -translate-y-1/2 inline-flex items-center justify-center bg-gold-600 hover:bg-gold-700 text-white font-medium text-sm px-5 py-2 rounded-lg transition-colors"
        >
          Cari
        </button>
      </form>
    </div>

    {
      !query && (
        <div class="text-center py-16">
          <div class="w-16 h-16 rounded-2xl bg-paper-200 flex items-center justify-center mx-auto mb-5">
            <Icon name="search" class="w-8 h-8 text-ink-300" />
          </div>
          <p class="text-ink-500 mb-5 font-medium">
            Atau coba pencarian cepat:
          </p>
          <div class="flex flex-wrap gap-2 justify-center">
            {[
              "Perda 2024",
              "Beasiswa",
              "Hutan adat",
              "Infrastruktur",
              "UMKM",
              "Kesehatan",
              "RTRW",
            ].map((tag) => (
              <a
                href={`/cari?q=${encodeURIComponent(tag)}`}
                class="inline-flex items-center gap-1.5 text-ink-600 hover:text-ink-900 hover:bg-paper-200 text-sm px-3.5 py-1.5 rounded-full border border-paper-300 transition-colors bg-white"
              >
                <Icon name="tag" class="w-3 h-3 text-ink-300" />
                {tag}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      query && filteredPolicies.length === 0 && (
        <div class="text-center py-16 bg-white border border-paper-200 rounded-xl">
          <div class="w-14 h-14 rounded-xl bg-paper-100 flex items-center justify-center mx-auto mb-4">
            <Icon name="search" class="w-7 h-7 text-ink-300" />
          </div>
          <p class="text-ink-700 font-semibold mb-1">
            Tidak ditemukan hasil untuk "{query}"
          </p>
          <p class="text-ink-400 text-sm mb-5">
            Coba kata kunci yang berbeda atau jelajahi per kategori.
          </p>
          <a
            href="/kategori"
            class="inline-flex items-center justify-center gap-1.5 bg-paper-200 hover:bg-paper-300 text-ink-700 font-medium text-sm px-4 py-2 rounded-lg border border-paper-300 transition-colors"
          >
            Jelajahi Kategori
          </a>
        </div>
      )
    }

    {
      query && filteredPolicies.length > 0 && (
        <div>
          <p class="text-ink-400 font-mono text-sm mb-4">
            {filteredPolicies.length} hasil untuk{" "}
            <span class="text-ink-700 font-semibold">"{query}"</span>
          </p>
          <div class="bg-white border border-paper-200 rounded-xl overflow-hidden shadow-sm divide-y divide-paper-100">
            {filteredPolicies.map((p) => {
              const cat = catMap[p.category];
              return (
                <a
                  href={`/kebijakan/${p.id}`}
                  class="flex items-start gap-4 px-5 py-4 hover:bg-paper-50 transition-colors group"
                >
                  <div class="shrink-0 pt-0.5 w-20">
                    <span class={typeBadge[p.type]}>{p.type}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-ink-400 text-xs font-mono mb-0.5">
                      {p.number}
                    </p>
                    <p class="text-ink-800 font-medium text-sm group-hover:text-gold-700 transition-colors leading-snug">
                      {p.title}
                    </p>
                    {cat && (
                      <p class="text-ink-400 text-xs mt-0.5 flex items-center gap-1">
                        <Icon name={cat.icon} class="w-3 h-3" />
                        {cat.name} · {p.year}
                      </p>
                    )}
                    <p class="text-ink-400 text-sm mt-1.5 line-clamp-2 hidden sm:block">
                      {p.summary}
                    </p>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      )
    }
  </div>
</MainLayout>
