---
import Icon from "./Icon.astro";
import { stats } from "../data/mockData";
---

<footer class="bg-white border-t border-paper-200 mt-20">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-3">
          <div
            class="w-7 h-7 rounded-md bg-gold-600 flex items-center justify-center"
          >
            <svg
              viewBox="0 0 24 24"
              class="w-4 h-4"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <ellipse
                cx="12"
                cy="10.5"
                rx="3.5"
                ry="4.5"
                fill="white"
                fill-opacity="0.9"></ellipse>
              <ellipse cx="12" cy="9.5" rx="2.5" ry="3.5" fill="#FBBF24"
              ></ellipse>
              <circle cx="12" cy="6.5" r="2" fill="white" fill-opacity="0.9"
              ></circle>
              <path
                d="M12 11.5 Q7.5 15 5.5 19.5 Q8.5 16.5 12 16 Q15.5 16.5 18.5 19.5 Q16.5 15 12 11.5Z"
                fill="white"
                fill-opacity="0.9"></path>
            </svg>
          </div>
          <span class="font-semibold text-ink-800">kastau</span>
        </a>
        <p class="text-ink-400 text-sm leading-relaxed mb-1">
          Tahu. Paham. Bersuara.
        </p>
        <p class="text-ink-300 text-xs leading-relaxed">
          Informasi kebijakan publik Kabupaten Jayapura, Papua.
        </p>
      </div>

      <!-- Jelajahi -->
      <div>
        <h4
          class="text-ink-600 text-xs font-semibold uppercase tracking-wider mb-4"
        >
          Jelajahi
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a
              href="/kebijakan"
              class="text-ink-400 hover:text-ink-700 text-sm transition-colors"
              >Kebijakan</a
            >
          </li>
          <li>
            <a
              href="/kategori"
              class="text-ink-400 hover:text-ink-700 text-sm transition-colors"
              >Kategori</a
            >
          </li>
          <li>
            <a
              href="/cari"
              class="text-ink-400 hover:text-ink-700 text-sm transition-colors"
              >Cari</a
            >
          </li>
        </ul>
      </div>

      <!-- Tentang -->
      <div>
        <h4
          class="text-ink-600 text-xs font-semibold uppercase tracking-wider mb-4"
        >
          Tentang
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a
              href="/cara-kerja"
              class="text-ink-400 hover:text-ink-700 text-sm transition-colors"
              >Cara Kerja</a
            >
          </li>
          <li>
            <a
              href="/tentang"
              class="text-ink-400 hover:text-ink-700 text-sm transition-colors"
              >Tentang Kastau</a
            >
          </li>
          <li>
            <a
              href="https://papuaopensource.github.io"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 text-ink-400 hover:text-ink-700 text-sm transition-colors"
            >
              Papua Open Source
              <Icon name="external-link" class="w-3.5 h-3.5" />
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4
          class="text-ink-600 text-xs font-semibold uppercase tracking-wider mb-4"
        >
          Legal
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a
              href="/privasi"
              class="text-ink-400 hover:text-ink-700 text-sm transition-colors"
              >Privasi</a
            >
          </li>
          <li>
            <a
              href="/syarat"
              class="text-ink-400 hover:text-ink-700 text-sm transition-colors"
              >Syarat Layanan</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="border-t border-paper-200 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3"
    >
      <p class="text-ink-300 text-xs">© 2026 Kastau</p>
      <p class="text-ink-300 text-xs">
        Dikembangkan oleh <a
          href="https://papuaopensource.github.io"
          target="_blank"
          rel="noopener"
          class="text-ink-400 hover:text-gold-600 font-medium transition-colors"
          >Papua Open Source</a
        > • Bukan afiliasi pemerintah resmi
      </p>
    </div>
  </div>
</footer>
